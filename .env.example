# --- Database ---
DATABASE_URL="postgresql://ceni:ceni_dev@localhost:5432/ceni"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-generate-a-random-secret"
AUTH_TRUST_HOST="true"

# --- Site ---
SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# OpenStreetMap raster tiles by default; point to your own tile server if needed.
NEXT_PUBLIC_TILE_URL="https://tile.openstreetmap.org/{z}/{x}/{y}.png"

# --- Uploads ---
# Vercel production: create a Vercel Blob store and set BLOB_READ_WRITE_TOKEN.
# Local development can keep the filesystem driver below.
STORAGE_DRIVER="local"
# STORAGE_DRIVER="vercel-blob"
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Local filesystem storage root.
UPLOAD_DIR="./data/uploads"

# --- Seed configuration ---
# Demo organizations and demo ORG user are created ONLY when "true".
# Set to "false" in production: only criteria, metrics, and the admin
# account below are seeded.
SEED_DEMO_DATA="true"

# --- Seed-only credentials (never hardcoded in code) ---
SEED_ADMIN_EMAIL="admin@ceni.local"
SEED_ADMIN_PASSWORD="Admin.CENI.2026!"
SEED_ORG_EMAIL="org@ceni.local"
SEED_ORG_PASSWORD="Org.CENI.2026!"
